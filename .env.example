# Copier vers `.env` et renseigner (le fichier `.env` ne doit pas être versionné).

# Flask-Mail — identifiants SMTP (ex. Gmail avec « mot de passe d'application »)
MAIL_SERVER=smtp.gmail.com
#
# Gmail : choisir UNE des deux combinaisons (sinon erreur « Connection unexpectedly closed ») :
#   • Port 587 (recommandé) : STARTTLS après connexion
#MAIL_PORT=587
#MAIL_USE_TLS=true
#MAIL_USE_SSL=false
#   • Port 465 : SSL dès la connexion (pas de STARTTLS)
#MAIL_PORT=465
#MAIL_USE_TLS=false
#MAIL_USE_SSL=true
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
# Adresse d'expédition (ex. aim@anc93.fr ou "ANC93 <aim@anc93.fr>")
MAIL_DEFAULT_SENDER=

# Optionnel
# MAIL_DEBUG=true
# SECRET_KEY=
# DATABASE_URL=
